# Database
DATABASE_URL="postgresql://massceo:massceo_dev@localhost:5432/massceo_tracker?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File uploads (local directory)
UPLOAD_DIR="./uploads"

# Mocked auth — set to a user ID from seed data to simulate login
# 1 = Staff Admin, 2 = Staff Editor, 3 = Board Member, 4 = Read Only
MOCK_USER_ID="1"

# Congress.gov API key (sign up at https://api.congress.gov/sign-up/)
CONGRESS_GOV_API_KEY=""

# Sync schedule (cron expression, default: every 6 hours)
SYNC_CRON_SCHEDULE="0 */6 * * *"
